OPENAI_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=

PARANOID_QA_PROVIDER=openai
PARANOID_QA_EMBED_PROVIDER=openai
PARANOID_QA_GEN_MODEL=gpt-4o-mini
PARANOID_QA_CRITIC_MODEL=gpt-5.4-nano
PARANOID_QA_EMBED_MODEL=text-embedding-3-small

# The critic must be a different model family from the generator (validated at startup).
PARANOID_QA_GEN_MODEL_FAMILY=gpt-4o
PARANOID_QA_CRITIC_MODEL_FAMILY=gpt-5.4

PARANOID_QA_CORPUS=data/corpus/sample
PARANOID_QA_STORAGE=.storage
PARANOID_QA_LIGHTRAG_DIR=.lightrag

PARANOID_QA_MAX_ATTEMPTS=2
PARANOID_QA_MAX_VERIFICATION_RETRIES=1
PARANOID_QA_TOP_K=10
PARANOID_QA_RERANK_TOP_N=4
PARANOID_QA_REQUEST_TIMEOUT_SECONDS=90
PARANOID_QA_MAX_CONCURRENT_REQUESTS=2
PARANOID_QA_MAX_QUERY_CHARS=1000

# Demo access control.
PARANOID_QA_DEMO_REQUIRE_ACCESS=true
PARANOID_QA_DEMO_INVITE_CODE=
PARANOID_QA_DEMO_SESSION_DAYS=7
PARANOID_QA_DEMO_QUESTIONS_PER_SESSION=20
PARANOID_QA_DEMO_GLOBAL_DAILY_LIMIT=100
PARANOID_QA_DEMO_DISABLED=false
